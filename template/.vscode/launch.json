{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Attach to Django (debugpy in k8s)",
      "type": "debugpy",
      "request": "attach",
      "connect": { "host": "127.0.0.1", "port": 5678 },
      "pathMappings": [
        { "localRoot": "${workspaceFolder}/backend", "remoteRoot": "/app/src" }
      ],
      "justMyCode": false
    }
  ]
}
